source/frontend/lexer.cpp:90: lexicalAnalysis: buffer:
def add{a1, b1} 
{{
    out a1 + b1;
}};

def mul{a2, b2} 
{{
    out a2 * b2;
}};

def calc{x, y} 
{{
    ID_def sum = add{x, y};
    ID_def prod = mul{x, y};
    print{sum};
    print{prod};
    print{sum+prod};
    out sum + prod;
}};

ID_def result = calc{3, 4};
print{result};
$
